# PartSourcer backend settings (copy to .env to override defaults).
# All values below are the built-in defaults; none are required for v1.

# Upstream jlcsearch API base URL (consumed by the datasource phase)
JLCSEARCH_BASE_URL=https://jlcsearch.tscircuit.com

# Cache TTLs in seconds (consumed by the caching phase)
SPECS_CACHE_TTL_SECS=2592000
STOCK_CACHE_TTL_SECS=3600

# SQLite cache DB path (consumed by the caching phase)
SQLITE_PATH=./partsourcer.db

# CORS allowed origins, JSON list (consumed by the harden phase)
CORS_ORIGINS=["*"]

# Outbound HTTP timeout in seconds (consumed by the datasource phase)
REQUEST_TIMEOUT_SECS=10.0
